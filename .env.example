# Copy to .env and fill in. .env is gitignored — your keys stay local.
# Same keys the predecessor (dnd-story-app) used.

# Narration audio (ElevenLabs). Required for `node render.js`.
ELEVENLABS_API_KEY=
# Optional per-language voices (the model is multilingual; only the voice differs).
# German defaults to 0oTMoyM0wBOiv66gewih; English to "Lily" pFZP5JQG7iQjIQuC4Bku.
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_ID_DE=
ELEVENLABS_VOICE_ID_EN=

# Images: anchors, covers, character avatars (OpenAI). Required for `--images`.
OPENAI_API_KEY=
