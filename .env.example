# Copy to .env and fill in. .env is gitignored — your keys stay local.
# Same keys the predecessor (dnd-story-app) used.

# Narration audio (ElevenLabs). Required for `node render.js`.
ELEVENLABS_API_KEY=
# Optional — defaults to the native-German voice 0oTMoyM0wBOiv66gewih
ELEVENLABS_VOICE_ID=

# Images: anchors, covers, character avatars (OpenAI). Required for `--images`.
OPENAI_API_KEY=
